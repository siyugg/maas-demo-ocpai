# Copy to backend/.env and fill in values for local development
# In-cluster deployments use the ConfigMap + secretKeyRef — this file is for local dev only.

# Granite-8B — use the external Route for local testing
GRANITE_ENDPOINT=https://granite-8b-maas-demo.apps.<cluster-domain>/v1
GRANITE_API_KEY=          # paste Bearer token from RHOAI service account secret
GRANITE_MODEL_NAME=granite-8b
GRANITE_VERIFY_SSL=true   # external Route has a valid cert

# Qwen3-8B — leave QWEN_ENDPOINT blank to disable
QWEN_ENDPOINT=https://qwen3-8b-maas-demo.apps.<cluster-domain>/v1
QWEN_API_KEY=             # paste Bearer token from RHOAI service account secret
QWEN_MODEL_NAME=qwen3-8b
QWEN_VERIFY_SSL=true

MCP_SERVER_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173
